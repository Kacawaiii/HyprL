# Secrets - NEVER commit
.env
telegram_bot/.env

# Environment / build
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.o
*.out
.pytest_cache/
*.egg-info/
.maturin_build/

# Data / artifacts
# Ignored wholesale, except a carved path to the small universe files the live
# engine needs at runtime on the CI runner. Git cannot re-include a file whose
# parent directory is excluded, hence opening the path one level at a time.
data/*
!data/momentum/
data/momentum/*
docs/experiments/
native/target/
native/**/target/
*.log
*.csv
*.json

# IDE
.vscode/
.idea/

# local outputs
live/exp/
live/logs/
configs/exp/
**/__pycache__/
.env.ops
.env.ops.example
.env.*
configs/runtime/.env.*
live/exp/
# audit/debug logs
live/logs/audit_trades_dryrun.jsonl
live/logs/*.jsonl
# Local broker env + execution outputs
.env.broker.alpaca
live/execution/

# Entitlements (sensitive)
apps/track_record/entitlements_allowlist.txt
data/entitlements.sqlite
data/db/*.db
apps/landing/.env

# Proprietary trading logic (private)
src/hyprl/strategy/
src/hyprl/features/
src/hyprl/live/
src/hyprl/backtest/
src/hyprl/risk/
src/hyprl/execution/
src/hyprl/meta/
src/hyprl/regime/
src/hyprl/adaptive/
models/
configs/*.yaml
configs/**/*.yaml
!configs/example.yaml

# Scripts (proprietary)
scripts/train*.py
scripts/backtest*.py
scripts/execution/
scripts/analysis/
scripts/ops/
scripts/cli/
scripts/marketing/

# Reports (private data)
reports/
docs/reports/

# Experiment runs (private)
runs/

# Sensitive scripts
scripts/run_*.py
scripts/go_live.py
scripts/sweep_*.py
scripts/validate_*.py
scripts/train_*.py
scripts/calibrate_*.py
scripts/evaluate_*.py
scripts/full_*.py
scripts/generate_*.py
scripts/prepare_*.py

# The engine needs the S&P universe + PIT membership at runtime on the CI runner;
# they are small text files, unlike the price parquets which stay ignored.
!data/momentum/sp500_current.json
!data/momentum/sp500_membership.csv
!data/momentum/ndx100_current.json

# Live trading data
live/*
# ...except the paper portfolio state: equity.jsonl is the public, git-timestamped
# track record, and heartbeat.json is what the watchdog reads. No secrets in here.
# The *.json rule above (line ~25) also catches these, so re-include explicitly.
!live/portfolio/
!live/portfolio/*.json
live/portfolio/last_alert.json
SECURITY_INTERVENTION_LOG.md
catboost_info/
run_paper.sh
scripts/download_mt5_5y.bat
scripts/paper_trading.py
